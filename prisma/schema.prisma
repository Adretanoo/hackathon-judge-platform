generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user account
model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  username             String               @unique
  fullName             String               @map("full_name")
  passwordHash         String               @map("password_hash")
  avatarUrl            String?              @map("avatar_url")
  bio                  String?
  /// JSON array of skill strings, e.g. ["TypeScript","Rust"]
  skills               Json                 @default("[]")
  isVerified           Boolean              @default(false) @map("is_verified")
  isActive             Boolean              @default(true) @map("is_active")
  isLookingForTeam     Boolean              @default(false) @map("is_looking_for_team")
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  organizedHackathons  Hackathon[]          @relation("HackathonOrganizer")
  judgeAssignments     JudgeAssignment[]
  judgeConflicts       JudgeConflict[]
  mentorAvailabilities MentorAvailability[]
  mentorExpertises     MentorExpertise[]
  bookedSlots          MentorSlot[]         @relation("SlotBooker")
  scores               Score[]
  studentInfo          StudentInfo?
  receivedInvites      TeamInvite[]         @relation("InviteReceiver")
  sentInvites          TeamInvite[]         @relation("InviteSender")
  teamMemberships      TeamMember[]
  roles                UserRole[]
  socials              UserSocial[]
  tokens               UserToken[]

  @@index([email])
  @@index([username])
  @@map("users")
}

/// JWT refresh tokens / device sessions
model UserToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("user_tokens")
}

/// OAuth / social accounts linked to a user
model UserSocial {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  /// "github" | "google" | "linkedin" | …
  provider     String
  providerId   String   @map("provider_id")
  profileUrl   String?  @map("profile_url")
  accessToken  String?  @map("access_token")
  refreshToken String?  @map("refresh_token")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("user_socials")
}

/// Named role definitions (seeded at startup)
model Role {
  id          String     @id @default(cuid())
  name        RoleName   @unique
  description String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("roles")
}

model UserRole {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  roleName    RoleName   @map("role_name")
  hackathonId String?    @map("hackathon_id")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  hackathon   Hackathon? @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleName, hackathonId])
  @@index([userId])
  @@index([hackathonId])
  @@map("user_roles")
}

/// One-to-one academic profile for student participants
model StudentInfo {
  id          String        @id @default(cuid())
  userId      String        @unique @map("user_id")
  studentCode String?       @unique @map("student_code")
  groupId     String?       @map("group_id")
  year        Int?
  gpa         Decimal?      @db.Decimal(4, 2)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  group       StudentGroup? @relation(fields: [groupId], references: [id])
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_info")
}

/// Academic specialty (e.g., "Computer Science")
model Specialty {
  id        String         @id @default(cuid())
  code      String         @unique
  name      String
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  groups    StudentGroup[]

  @@map("specialties")
}

/// Academic group within a specialty
model StudentGroup {
  id           String        @id @default(cuid())
  specialtyId  String        @map("specialty_id")
  name         String        @unique
  year         Int
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  specialty    Specialty     @relation(fields: [specialtyId], references: [id])
  studentInfos StudentInfo[]

  @@index([specialtyId])
  @@map("student_groups")
}

/// Main hackathon event record
model Hackathon {
  id                   String                 @id @default(cuid())
  organizerId          String                 @map("organizer_id")
  title                String
  subtitle             String?
  description          String?
  isOnline             Boolean                @default(true) @map("is_online")
  location             String?
  bannerUrl            String?                @map("banner_url")
  websiteUrl           String?                @map("website_url")
  status               HackathonStatus        @default(DRAFT)
  minTeamSize          Int                    @default(1) @map("min_team_size")
  maxTeamSize          Int                    @default(5) @map("max_team_size")
  registrationDeadline DateTime?              @map("registration_deadline") @db.Timestamptz(6)
  startDate            DateTime               @map("start_date") @db.Timestamptz(6)
  endDate              DateTime               @map("end_date") @db.Timestamptz(6)
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  awards               Award[]
  tags                 HackathonTagRelation[]
  organizer            User                   @relation("HackathonOrganizer", fields: [organizerId], references: [id])
  judgeAssignments     JudgeAssignment[]
  mentorAvailabilities MentorAvailability[]
  stages               Stage[]
  teams                Team[]
  tracks               Track[]
  userRoles            UserRole[]

  @@index([organizerId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("hackathons")
}

/// A phase / stage of a hackathon (e.g., "Submission", "Judging")
model Stage {
  id          String    @id @default(cuid())
  hackathonId String    @map("hackathon_id")
  name        String
  description String?
  orderIndex  Int       @map("order_index")
  startDate   DateTime  @map("start_date") @db.Timestamptz(6)
  endDate     DateTime  @map("end_date") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, orderIndex])
  @@index([hackathonId])
  @@map("stages")
}

/// Competition track within a hackathon (e.g., "AI/ML", "Web3")
model Track {
  id               String            @id @default(cuid())
  hackathonId      String            @map("hackathon_id")
  name             String
  description      String?
  maxTeams         Int?              @map("max_teams")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  criteria         Criteria[]
  mentorExpertises MentorExpertise[]
  teams            Team[]
  hackathon        Hackathon         @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, name])
  @@index([hackathonId])
  @@map("tracks")
}

/// Tag vocabulary (reusable across hackathons)
model HackathonTag {
  id         String                 @id @default(cuid())
  name       String                 @unique
  slug       String                 @unique
  createdAt  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  hackathons HackathonTagRelation[]

  @@map("hackathon_tags")
}

/// Many-to-many join between Hackathon and HackathonTag
model HackathonTagRelation {
  hackathonId String       @map("hackathon_id")
  tagId       String       @map("tag_id")
  hackathon   Hackathon    @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  tag         HackathonTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([hackathonId, tagId])
  @@map("hackathon_tag_relations")
}

/// Prize / award defined for a hackathon (1st, 2nd, track winner …)
model Award {
  id          String    @id @default(cuid())
  hackathonId String    @map("hackathon_id")
  title       String
  description String?
  prize       String?
  rank        Int?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@index([hackathonId])
  @@map("awards")
}

/// A team participating in a hackathon
model Team {
  id             String          @id @default(cuid())
  hackathonId    String          @map("hackathon_id")
  trackId        String?         @map("track_id")
  name           String
  description    String?
  logoUrl        String?         @map("logo_url")
  status         TeamStatus      @default(FORMING)
  isOpen         Boolean         @default(true) @map("is_open")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  judgeConflicts JudgeConflict[]
  projects       Project[]
  invites        TeamInvite[]
  members        TeamMember[]
  hackathon      Hackathon       @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  track          Track?          @relation(fields: [trackId], references: [id])

  @@unique([hackathonId, name])
  @@index([hackathonId])
  @@index([trackId])
  @@map("teams")
}

/// User membership record inside a team
model TeamMember {
  id        String         @id @default(cuid())
  teamId    String         @map("team_id")
  userId    String         @map("user_id")
  role      TeamMemberRole @default(MEMBER)
  joinedAt  DateTime       @default(now()) @map("joined_at") @db.Timestamptz(6)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

/// Invitation sent to a user to join a team
model TeamInvite {
  id         String       @id @default(cuid())
  teamId     String       @map("team_id")
  senderId   String       @map("sender_id")
  receiverId String?      @map("receiver_id")
  token      String       @unique
  status     InviteStatus @default(PENDING)
  maxUses    Int          @default(1) @map("max_uses")
  usesCount  Int          @default(0) @map("uses_count")
  message    String?
  expiresAt  DateTime     @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  receiver   User?        @relation("InviteReceiver", fields: [receiverId], references: [id])
  sender     User         @relation("InviteSender", fields: [senderId], references: [id])
  team       Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([token])
  @@map("team_invites")
}

/// Project submission by a team
model Project {
  id           String            @id @default(cuid())
  teamId       String            @map("team_id")
  title        String
  description  String?
  repoUrl      String?           @map("repo_url")
  demoUrl      String?           @map("demo_url")
  videoUrl     String?           @map("video_url")
  techStack    String[]          @map("tech_stack")
  status       ProjectStatus     @default(DRAFT)
  submittedAt  DateTime?         @map("submitted_at") @db.Timestamptz(6)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  averageScore Decimal?          @map("average_score") @db.Decimal(10, 2)
  totalScore   Decimal?          @map("total_score") @db.Decimal(10, 2)
  resources    ProjectResource[]
  team         Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scores       Score[]

  @@index([teamId])
  @@index([status])
  @@map("projects")
}

/// Additional file / link attached to a project
model ProjectResource {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  label     String
  url       String
  mimeType  String?  @map("mime_type")
  sizeBytes BigInt?  @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_resources")
}

/// Marks a mentor as an expert in a specific track
model MentorExpertise {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  trackId   String   @map("track_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@map("mentor_expertises")
}

/// Declares when a mentor is available during a hackathon
model MentorAvailability {
  id                  String       @id @default(cuid())
  mentorId            String       @map("mentor_id")
  hackathonId         String       @map("hackathon_id")
  startDatetime       DateTime     @map("start_datetime") @db.Timestamptz(6)
  endDatetime         DateTime     @map("end_datetime") @db.Timestamptz(6)
  slotDurationMinutes Int          @default(30) @map("slot_duration_minutes")
  isBlocked           Boolean      @default(false) @map("is_blocked")
  blockReason         String?      @map("block_reason")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  hackathon           Hackathon    @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  mentor              User         @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  slots               MentorSlot[]

  @@index([mentorId, hackathonId])
  @@map("mentor_availabilities")
}

/// Individual bookable time slot generated from a MentorAvailability block
model MentorSlot {
  id             String             @id @default(cuid())
  availabilityId String             @map("availability_id")
  startDatetime  DateTime           @map("start_datetime") @db.Timestamptz(6)
  endDatetime    DateTime           @map("end_datetime") @db.Timestamptz(6)
  status         SlotStatus         @default(AVAILABLE)
  bookedById     String?            @map("booked_by_id")
  teamId         String?            @map("team_id")
  meetingUrl     String?            @map("meeting_url")
  notes          String?
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  availability   MentorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  bookedBy       User?              @relation("SlotBooker", fields: [bookedById], references: [id])

  @@index([availabilityId])
  @@index([status])
  @@map("mentor_slots")
}

/// Scoring criterion for a specific track
model Criteria {
  id          String   @id @default(cuid())
  trackId     String   @map("track_id")
  name        String
  description String?
  weight      Decimal  @default(1.0) @db.Decimal(5, 2)
  maxScore    Decimal  @default(10) @map("max_score") @db.Decimal(5, 2)
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  scores      Score[]

  @@index([trackId])
  @@map("criteria")
}

/// Assignment of a judge to a hackathon (optionally to a specific track)
model JudgeAssignment {
  id          String    @id @default(cuid())
  judgeId     String    @map("judge_id")
  hackathonId String    @map("hackathon_id")
  trackId     String?   @map("track_id")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  judge       User      @relation(fields: [judgeId], references: [id], onDelete: Cascade)

  @@unique([judgeId, hackathonId, trackId])
  @@index([hackathonId])
  @@map("judge_assignments")
}

/// Conflict of interest declaration between a judge and a team
model JudgeConflict {
  id              String       @id @default(cuid())
  judgeId         String       @map("judge_id")
  teamId          String       @map("team_id")
  type            ConflictType
  reason          String?      @db.Text
  detectedAt      DateTime     @default(now()) @map("detected_at") @db.Timestamptz(6)
  overridden      Boolean      @default(false)
  overrideReason  String?      @map("override_reason") @db.Text
  overriddenBy    String?      @map("overridden_by")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  judge           User         @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  team            Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([judgeId, teamId])
  @@index([judgeId])
  @@index([teamId])
  @@map("judge_conflicts")
}

/// Score given by a judge to a project for a specific criterion
model Score {
  id         String   @id @default(cuid())
  judgeId    String   @map("judge_id")
  projectId  String   @map("project_id")
  criteriaId String   @map("criteria_id")
  scoreValue Decimal  @map("score_value") @db.Decimal(5, 2)
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  criteria   Criteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  judge      User     @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([judgeId, projectId, criteriaId])
  @@index([projectId])
  @@index([judgeId])
  @@map("scores")
}

/// Global platform roles (also used as hackathon-scoped roles via UserRole)
enum RoleName {
  GLOBAL_ADMIN
  ORGANIZER
  JUDGE
  MENTOR
  PARTICIPANT
}

/// Lifecycle status of a hackathon
enum HackathonStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  JUDGING
  COMPLETED
  ARCHIVED
}

/// Membership status of a team
enum TeamStatus {
  FORMING
  COMPLETE
  SUBMITTED
  DISQUALIFIED
}

/// Role of a member inside a team
enum TeamMemberRole {
  CAPTAIN
  MEMBER
}

/// Lifecycle status of a team invitation
enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

/// Submission status of a project
enum ProjectStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  DISQUALIFIED
}

/// Reason a judge is in conflict with a team
enum ConflictType {
  TEAM_MEMBER
  SUPERVISOR
  PERSONAL
  MENTORED_TEAM
  RELATIVE
  OTHER
}

/// Mentor slot booking state
enum SlotStatus {
  AVAILABLE
  BOOKED
  CANCELLED
  COMPLETED
}

/// Global dynamic configuration storage
model SystemConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_configs")
}
